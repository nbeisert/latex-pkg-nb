  \immediate\write\@auxout{\string\sti@noteblocktotal
    {\thesti@chapter}{\thesti@block}{\thesti@blocktime}}}

\newcommand{\sti@blocktotalcurrent}[1][??]{%
  \expandafter\let\expandafter\timingreturn
