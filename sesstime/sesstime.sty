\providecommand\timingprintchapter[1]{\timingprintmark{\raisebox{2.8ex}{%
  \textbf{\timingchaptertotal*{#1}\timingreturn}%
  \rlap{\kern0.4em$\star$}\kern1.2em}}}

\newcommand{\timingchapter}[1][]{%
  \sti@processflags{#1}%
  \ifsti@flag
    \ifodd\c@sti@inblock
      \PackageWarning{sesstime}{chapter: still in block; stopped}%
      \sti@warn{chap}%
      \sti@blockstop{}{}{0}%
    \fi
    \timingchapterend
    \c@sti@inchapter\@ne
    \c@sti@chaptertime\z@
    \advance\c@sti@chapter\@ne
    \c@sti@block\z@
    \ifsti@printchapter\timingprintchapter\thesti@chapter\fi
  \fi\ignorespaces}

\newcommand{\timingchapterend}[1][]{%
  \sti@processflags{#1}%
  \ifsti@flag
    \ifodd\c@sti@inblock
      \PackageWarning{sesstime}{chapterend: still in block; stopped}%
      \sti@warn{chap}%
      \sti@blockstop{}{}{0}%
    \fi
    \ifodd\c@sti@inchapter
      \sti@writechaptertotal
      \c@sti@inchapter\z@
      \c@sti@chaptertime\z@
    \fi
  \fi\ignorespaces}
\AtEndDocument{\timingchapterend}

