  \ifx\timingreturn\relax\def\timingreturn{#1}\fi}
\newcommand{\timingblocktotal}{%
  \@ifstar\sti@blocktotalnext\sti@blocktotalcurrent}

\newcommand{\timingprintblock}[3]{\timingprintmark{%
  \def\sti@tmp{#2}\ifx\sti@tmp\@empty
    \raisebox{-1ex}{#1\rlap{\kern0.4em$\Updownarrow$}}\kern1.2em%
  \else
    \def\sti@tmp{#1}\ifx\sti@tmp\@empty\else
      #1\rlap{\kern0.4em$\Uparrow$%
      \vphantom{$\Updownarrow$}}\kern1.2em\hrule\fi
    \textbf{#2}\rlap{\vphantom{$\Updownarrow$}}\kern1.2em%
    \def\sti@tmp{#3}\ifx\sti@tmp\@empty\else
      \hrule#3\rlap{\kern0.4em$\Downarrow$%
      \vphantom{$\Updownarrow$}}\kern1.2em\fi
  \fi}}

\newcommand{\sti@advance}{%
  \ifodd\c@sti@inblock\advance\c@sti@blocktime\sti@delta\fi
  \ifodd\c@sti@inchapter\advance\c@sti@chaptertime\sti@delta\fi
  \ifodd\c@sti@insession\advance\c@sti@sessiontime\sti@delta\fi}

\def\sti@hoursminutes#1:#2:#3!{%
  \sti@delta\numexpr#1\relax
  \if!#3!\else
    \sti@delta\numexpr60*\sti@delta+#2\relax
  \fi}

\newcommand{\sti@computedelta}{%
  \advance\sti@delta\numexpr-\c@sti@blockgauge-\c@sti@blocktime\relax}

\newcommand{\sti@warnneg}{%
  \ifnum\sti@delta<\z@
    \PackageWarning{sesstime}{block: negative time elapsed}%
    \sti@warn{neg}%
  \fi}

\newcommand{\sti@blockstart}[3]{%
  \sti@processflags{#1}%
  \ifsti@flag
    \ifodd\c@sti@inblock
      \PackageWarning{sesstime}{already in block}%
      \sti@warn{block}
    \else
      \sti@hoursminutes#3::!%
      #2%
      \c@sti@inblock\@ne
      \advance\c@sti@blockgauge\numexpr\c@sti@blocktime+\sti@delta\relax
      \c@sti@blocktime\z@
      \advance\c@sti@block\@ne
      \sti@checksession
      \ifsti@printblock
        \sti@blocktotalcurrent
        \timingprintblock{}\thesti@chaptertime\timingreturn
      \fi
    \fi
  \fi\nopagebreak}
\newcommand{\sti@blockstartat}[1][]{\sti@blockstart{#1}\sti@computedelta}
\newcommand{\sti@blockstartby}[1][]{\sti@blockstart{#1}{}}
\newcommand{\timingstart}{\@ifstar\sti@blockstartby\sti@blockstartat}

\newcommand{\sti@blocksplit}[3]{%
  \sti@processflags{#1}%
  \ifsti@flag
    \ifodd\c@sti@inblock
      \sti@hoursminutes#3::!%
      #2%
      \sti@warnneg
      \sti@advance
      \sti@checksession
      \ifsti@printblock
        \timingprintblock\thesti@blocktime{}{}%
      \fi
    \else
      \PackageWarning{sesstime}{not in block}%
      \sti@warn{block}%
    \fi
  \fi}
\newcommand{\sti@blocksplitat}[1][]{\sti@blocksplit{#1}\sti@computedelta}
\newcommand{\sti@blocksplitby}[1][]{\sti@blocksplit{#1}{}}
\newcommand{\timingsplit}{\@ifstar\sti@blocksplitby\sti@blocksplitat}

\newcommand{\sti@blockstop}[3]{%
  \sti@processflags{#1}%
  \ifsti@flag
    \ifodd\c@sti@inblock
      \sti@hoursminutes#3::!%
      #2%
      \sti@warnneg
      \sti@advance
      \sti@writeblocktotal
      \ifsti@printblock
        \timingprintblock\thesti@blocktime\thesti@chaptertime{}%
      \fi
      \c@sti@inblock\z@
      \c@sti@blocktime\z@
    \else
      \PackageWarning{sesstime}{not in block}%
      \sti@warn{block}%
    \fi
  \fi}
\newcommand{\sti@blockstopat}[1][]{\sti@blockstop{#1}\sti@computedelta}
\newcommand{\sti@blockstopby}[1][]{\sti@blockstop{#1}{}}
\newcommand{\timingstop}{\@ifstar\sti@blockstopby\sti@blockstopat}

\newcommand{\sti@blocknext}[3]{%
  \sti@processflags{#1}%
  \ifsti@flag
    \ifodd\c@sti@inblock
      \sti@hoursminutes#3::!%
      #2%
      \sti@warnneg
      \sti@advance
      \sti@writeblocktotal
      \advance\c@sti@block\@ne
      \ifsti@printblock
        \sti@blocktotalcurrent
        \timingprintblock\thesti@blocktime\thesti@chaptertime\timingreturn
      \fi
      \advance\c@sti@blockgauge\c@sti@blocktime
      \c@sti@blocktime\z@
      \sti@checksession
    \else
      \PackageWarning{sesstime}{not in block}%
      \sti@warn{block}%
    \fi
  \fi}
\newcommand{\sti@blocknextat}[1][]{\sti@blocknext{#1}\sti@computedelta}
\newcommand{\sti@blocknextby}[1][]{\sti@blocknext{#1}{}}
\newcommand{\timingnext}{\@ifstar\sti@blocknextby\sti@blocknextat}

\newcommand{\timinglapse}[2][]{%
  \sti@processflags{#1}%
  \ifsti@flag
    \sti@hoursminutes#2::!%
    \ifodd\c@sti@inblock
      \advance\c@sti@blockgauge-\sti@delta
    \fi
    \sti@advance
  \fi}

\newcommand{\timinggauge}[2][]{%
  \sti@processflags{#1}%
  \ifsti@flag
    \sti@hoursminutes#2::!%
    \sti@computedelta
    \advance\c@sti@blockgauge\sti@delta
  \fi}

