  \setbox\@ne=\hbox{$\m@th#1\mskip\muexpr\mafx@uproot mu\relax$}%
  \dimen@\dimexpr0.6\ht\z@-0.6\dp\z@+\wd\@ne\relax
  \mkern-\muexpr\mafx@leftroot mu\relax
  \raise\dimen@\copy\rootbox
  \mkern\muexpr\mafx@leftroot mu\relax
  \kern-0.6\wd\z@
  \mkern\muexpr\mafx@root@preskip\relax
  \sqrtsign{#2\mskip\muexpr\mafx@root@endskip\relax}%
  \ifx\mafx@root@close\@empty\else
  \dimen@\fontdimen8\mafx@tmp@fontsel3\relax
