    \advance\dimen@-0.25\fontdimen5\textfont2\relax
  \else
    \advance\dimen@-1.25\fontdimen8\mafx@tmp@fontsel3\relax
  \fi
  \setbox\z@=\hbox{$\m@th#1\sqrtsign{%
    \vrule width\z@ height\dimen@ depth\dp\z@}$}%
  \dimen@\dimexpr0.6\wd\z@-\wd\rootbox\relax
  \ifdim\dimen@>\z@\else\dimen@\z@\fi
